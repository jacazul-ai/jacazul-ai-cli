#!/bin/bash
# 🐊 tw-flow (Legacy Wrapper)
# Forwards execution to the new jacazul-ai-cli package entry point.

HATCH_BIN="$HOME/.jacazul-ai/.venv/bin/tw-flow"

if [ -x "$HATCH_BIN" ]; then
    exec "$HATCH_BIN" "$@"
else
    # Fallback to direct execution if not installed
    PYTHONPATH="$(dirname "$(dirname "$(dirname "$(dirname "$(readlink -f "$0")")")")")"
    exec python3 "$PYTHONPATH/jacazul/cli/flow.py" "$@"
fi
