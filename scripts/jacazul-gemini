#!/bin/bash
# jacazul-gemini: Gemini CLI unhinged (direct execution)

# Get the absolute path to the script's directory
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
PROJECT_ROOT="$(readlink -f "$SCRIPT_DIR/..")"

# -----------------------------------------------------------------------------
# Runtime Bootstrap (Dynamics)
# -----------------------------------------------------------------------------
BOOTSTRAP_ENV="$PROJECT_ROOT/scripts/bootstrap/environment"
if [ -f "$BOOTSTRAP_ENV" ]; then
    source "$BOOTSTRAP_ENV"
else
    echo "❌ Jacazul runtime environment not found at $BOOTSTRAP_ENV" >&2
    exit 1
fi

# Export all context variables
export PROJECT_ID="$PROJECT_ID"
export CONTEXT_REAL_PATH="$(pwd)"
export CONTEXT_SYSTEM_USER="$(whoami)"
export CONTEXT_GIT_USER="${CONTEXT_GIT_USER:-$(whoami)}"
export GEMINI_INSTRUCTIONS_DIR="$PROJECT_ROOT/templates/context/instructions"

# Add workflow scripts to PATH
export PATH="$PATH:$PROJECT_ROOT/skills/taskwarrior_expert/scripts"

# Base Onboard Prompt for Jacazul (Gemini Edition)
ONBOARD_PROMPT="The anchored persona for this session is Jacazul (Jacaré Azul), running $JACAZUL_MODE. Activate the 'jacazul-engine' and 'taskwarrior-expert' skills immediately, in parallel with tactical context discovery (tw-flow focus + ponder). This initializes the session OS before the first response. Respond in persona (signature: 🐊 Jacazul)."

# If no arguments provided, default to deterministic onboarding
if [ $# -eq 0 ]; then
    set -- -i "$ONBOARD_PROMPT"
else
    USER_PROMPT="$*"
    set -- -i "$ONBOARD_PROMPT" "$USER_PROMPT"
fi

# Check if gemini is installed
if ! command -v gemini &> /dev/null; then
    echo "❌ gemini command not found in PATH." >&2
    exit 1
fi

[ -n "$DEBUG" ] && echo "🐊 jacazul-gemini: Starting for project [$PROJECT_ID]"

# DRY RUN: Exit before execution if DRY is set
if [ -n "$DRY" ]; then
    echo "✅ Dry run complete. Gemini bootstrap verified for project [$PROJECT_ID]."
    exit 0
fi

exec gemini "$@"
