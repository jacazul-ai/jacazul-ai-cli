#!/bin/bash
# 🐊 Jacazul - Bootstrap for Gemini CLI Settings
# Configures experimental agents and preview features surgically.

# Localiza o diretório raiz do projeto
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
TEMPLATES_DIR="$PROJECT_ROOT/templates"

GEMINI_DIR="${1:-$HOME/.gemini}"
SETTINGS_FILE="$GEMINI_DIR/settings.json"
TEMPLATE_SETTINGS="$PROJECT_ROOT/templates/gemini/unhinged/settings.json"

# 1. Garante que o diretório existe
if [ ! -d "$GEMINI_DIR" ]; then
    echo "🐊 Creating Gemini directory at $GEMINI_DIR..."
    mkdir -p "$GEMINI_DIR"
fi

# 2. Garante que o settings.json existe (usa template se disponível)
if [ ! -f "$SETTINGS_FILE" ]; then
    if [ -f "$TEMPLATE_SETTINGS" ]; then
        echo "🐊 Initializing Gemini settings.json from template..."
        cp "$TEMPLATE_SETTINGS" "$SETTINGS_FILE"
    else
        echo "{}" > "$SETTINGS_FILE"
    fi
fi

# 3. Update cirúrgico com jq
# Mantém o que já existe e só garante os campos necessários
TMP_FILE=$(mktemp)
jq '
    .experimental.enableAgents = true | 
    .general.previewFeatures = true
' "$SETTINGS_FILE" > "$TMP_FILE" && mv "$TMP_FILE" "$SETTINGS_FILE"

# 4. Link Global Skills (Surgical)
SKILLS_DIR="$GEMINI_DIR/skills"
mkdir -p "$SKILLS_DIR"

# 4.1 Link skills from root-level /skills directory
for skill_dir in "$PROJECT_ROOT/skills"/*; do
    [ -d "$skill_dir" ] || continue
    name=$(basename "$skill_dir")

    target="$SKILLS_DIR/$name"
    # Always ensure the link points to the CURRENT PROJECT_ROOT
    if [ -L "$target" ]; then
        current_target=$(readlink -f "$target")
        expected_target=$(readlink -f "$skill_dir")
        if [ "$current_target" != "$expected_target" ]; then
            if [ -n "$DEBUG" ]; then
                echo "⚠️  Gemini skill $name points to wrong location. Re-linking..."
            fi
            ln -sf "$skill_dir" "$target"
        fi
    else
        if [ -n "$DEBUG" ]; then
            echo "🐊 Linking global Gemini skill: $name"
        fi
        ln -sf "$skill_dir" "$target"
    fi
done

# 4.2 Link legacy skills from templates (if any left)
if [ -d "$TEMPLATES_DIR/skills" ]; then
    for skill_dir in "$TEMPLATES_DIR/skills"/*; do
        [ -d "$skill_dir" ] || continue
        name=$(basename "$skill_dir")

        # Skip if already linked from root
        [ -e "$SKILLS_DIR/$name" ] && continue

        target="$SKILLS_DIR/$name"
        if [ -n "$DEBUG" ]; then
            echo "🐊 Linking legacy Gemini skill from templates: $name"
        fi
        ln -sf "$skill_dir" "$target"
    done
fi

# Log only in DEBUG mode
if [ -n "$DEBUG" ]; then
    echo "✅ Jacazul: Gemini configuration verified (enableAgents: true, previewFeatures: true)."
fi
