#!/bin/bash
# 🐊 Jacazul Hatch Bootstrap
# Centralized JIT Prompt Forge trigger for the current session.

# Determine the absolute project root directory
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
HATCH_BIN="$HOME/.jacazul-ai/.venv/bin/jacazul-hatch"

if [ -x "$HATCH_BIN" ]; then
    # Hatch all clients to ensure total pântano alignment
    "$HATCH_BIN" --client gemini
    "$HATCH_BIN" --client copilot
    "$HATCH_BIN" --client opencode
else
    echo "⚠️  Hatch entry point not found at $HATCH_BIN. Falling back to direct script..."
    HATCH_ENGINE="$PROJECT_ROOT/jacazul/cli/hatch.py"
    if [ -x "$HATCH_ENGINE" ]; then
        "$HATCH_ENGINE" --client gemini
        "$HATCH_ENGINE" --client copilot
        "$HATCH_ENGINE" --client opencode
    else
        echo "❌ Hatch engine not found."
    fi
fi
