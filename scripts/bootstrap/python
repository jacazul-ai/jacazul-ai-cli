#!/bin/bash
# 🐊 Jacazul Python Bootstrap (Unhinged Mode)
# Manages the persistent Python venv using 'uv'.

VENV_DIR="$HOME/.jacazul-ai/.venv"
REQUIREMENTS_FILE="$PROJECT_ROOT/templates/python/requirements.txt"

# 0. Kill existing shell VENV if it points to legacy paths
# This prevents 'uv' from exploding due to an active, broken environment.
unset VIRTUAL_ENV

# 1. Ensure the venv directory exists and is valid
RECREATE_VENV=false
if [ ! -d "$VENV_DIR" ]; then
    RECREATE_VENV=true
elif ! "$VENV_DIR/bin/python" --version &>/dev/null; then
    echo "⚠️  Python venv at $VENV_DIR is invalid or broken. Recreating..."
    RECREATE_VENV=true
fi

if [ "$RECREATE_VENV" = true ]; then
    echo "🐊 Initializing persistent Python venv at $VENV_DIR..."
    rm -rf "$VENV_DIR"
    mkdir -p "$(dirname "$VENV_DIR")"
    if command -v uv &> /dev/null; then
        uv venv "$VENV_DIR"
    else
        python3 -m venv "$VENV_DIR"
    fi
fi

# 2. Activate the venv
# shellcheck source=/dev/null
source "$VENV_DIR/bin/activate"

# 3. Sync dependencies if requirements.txt exists and we are in DEBUG or first run
if [ -f "$REQUIREMENTS_FILE" ]; then
    if [ -n "$DEBUG" ]; then
        echo "🐊 Syncing Python dependencies via 'uv'..."
        uv pip install -r "$REQUIREMENTS_FILE"
    fi
fi

# Log status in DEBUG mode
if [ -n "$DEBUG" ]; then
    echo "✅ Jacazul: Python environment ready ($VENV_DIR)."
fi
