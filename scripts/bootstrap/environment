#!/bin/bash
# 🐊 Jacazul Bootstrap - Environment Check
# This script is the SOLE entry point for runtime configuration (Dynamics).

# 1. Run-once Guard
if [ -n "$JACAZUL_ENV_INITIALIZED" ]; then
    return 0
fi

# 2. Dynamic Detection of Real Taskwarrior Binary
if [ -z "$JACAZUL_REAL_TASK" ]; then
    JACAZUL_REAL_TASK=$(which -a task 2>/dev/null | grep -v "$PROJECT_ROOT/scripts/task" | head -n 1)
    if [ -z "$JACAZUL_REAL_TASK" ]; then
        for p in /usr/bin/task /usr/local/bin/task /opt/homebrew/bin/task; do
            if [ -x "$p" ]; then JACAZUL_REAL_TASK="$p"; break; fi
        done
    fi
    export JACAZUL_REAL_TASK
fi

# 2.1 Taskwarrior/OS Detection
if [ -z "$JACAZUL_TASK_VERSION" ]; then
    if [ -n "$JACAZUL_REAL_TASK" ]; then
        JACAZUL_TASK_VERSION=$("$JACAZUL_REAL_TASK" --version | head -n 1 | cut -d'.' -f1)
    else
        # Task missing - Detect by package manager
        if command -v dnf &> /dev/null; then
            # Fedora/RedHat - Likely Task 3
            JACAZUL_TASK_VERSION="3"
            export JACAZUL_HOST_OS="fedora"
        elif command -v apt-get &> /dev/null; then
            # Debian/Ubuntu - Likely Task 2
            JACAZUL_TASK_VERSION="2"
            export JACAZUL_HOST_OS="debian"
        fi
    fi
    export JACAZUL_TASK_VERSION
fi

# 2.2 Administrative Alias
# Provides a session-specific bypass to the real binary for project maintenance.
alias rtask="$JACAZUL_REAL_TASK"

# 3. Project Identity Calculation
if [ -z "$PROJECT_ID" ]; then
    PARENT_DIR=$(basename "$(dirname "$(pwd)")")
    CURRENT_DIR=$(basename "$(pwd)")
    export PROJECT_ID="${PARENT_DIR}_${CURRENT_DIR}"
fi

# 4. Mode Configuration
export JACAZUL_MODE="${JACAZUL_MODE:-COUNSELOR}"

# 4. Component Bootstraps (Dynamics)
# 4.0 Language (Idiom)
BOOTSTRAP_LANG="$PROJECT_ROOT/scripts/bootstrap/language"
[ -f "$BOOTSTRAP_LANG" ] && source "$BOOTSTRAP_LANG"

# 4.1 Health Check (Critical Binaries)
TW_FLOW_BIN="$HOME/.jacazul-ai/.venv/bin/tw-flow"
if [ ! -x "$TW_FLOW_BIN" ]; then
    # Fallback to legacy path if venv not ready yet
    TW_FLOW_BIN="$PROJECT_ROOT/skills/taskwarrior_expert/scripts/tw-flow"
fi

if [ ! -x "$TW_FLOW_BIN" ]; then
    echo "❌ CRITICAL ERROR: tw-flow not found or not executable." >&2
    echo "   The workspace structure might be corrupted. Please run 'scripts/configure' to fix it." >&2
    return 1 2>/dev/null || exit 1
fi

# 4.1 Python VENV (Foundation)
BOOTSTRAP_PYTHON="$PROJECT_ROOT/scripts/bootstrap/python"
[ -f "$BOOTSTRAP_PYTHON" ] && source "$BOOTSTRAP_PYTHON"

# 4.2 JIT Prompt Hatching (The Forge)
BOOTSTRAP_HATCH="$PROJECT_ROOT/scripts/bootstrap/hatch"
[ -x "$BOOTSTRAP_HATCH" ] && "$BOOTSTRAP_HATCH"

# 4.3 Taskwarrior
BOOTSTRAP_TW="$PROJECT_ROOT/scripts/bootstrap/taskwarrior"
[ -f "$BOOTSTRAP_TW" ] && source "$BOOTSTRAP_TW"

# 4.4 Gemini
BOOTSTRAP_GEMINI="$PROJECT_ROOT/scripts/bootstrap/gemini"
[ -f "$BOOTSTRAP_GEMINI" ] && source "$BOOTSTRAP_GEMINI" "$HOME/.gemini"

# 5. Finalize Initialization
export JACAZUL_ENV_INITIALIZED=true

# Initial feedback - ONLY if DEBUG is set
if [ -n "$DEBUG" ]; then
    echo "🐊 Jacazul Runtime Initialized | Mode: $JACAZUL_MODE | Binary: ${JACAZUL_REAL_TASK:-not found}"
fi
