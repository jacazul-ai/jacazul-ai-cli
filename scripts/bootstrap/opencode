#!/bin/bash
# 🐊 Jacazul - Bootstrap for Opencode (Global UNHINGED Mode)
# Sets up global agents and skills for native Gemini CLI execution.

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
OPENCODE_GLOBAL_DIR="$HOME/.config/opencode"
TEMPLATES_DIR="$PROJECT_ROOT/templates"

# 1. Garante que os diretórios globais existem
if [ ! -d "$OPENCODE_GLOBAL_DIR/agents" ] || [ ! -d "$OPENCODE_GLOBAL_DIR/skills" ]; then
    echo "🐊 Initializing global Opencode directories at $OPENCODE_GLOBAL_DIR..."
    mkdir -p "$OPENCODE_GLOBAL_DIR/agents" "$OPENCODE_GLOBAL_DIR/skills"
fi

# 2. Link Global Agents (Surgical)
AGENT_SRC="$PROJECT_ROOT/agents/jacazul-opencode.md"
AGENT_TARGET="$OPENCODE_GLOBAL_DIR/agents/jacazul.agent.md"

if [ -e "$AGENT_SRC" ]; then
    echo "🐊 Linking global Gemini agent: jacazul"
    ln -sf "$AGENT_SRC" "$AGENT_TARGET"
fi

# 3. Link Global Skills (Surgical)
for skill_dir in "$PROJECT_ROOT/skills/jacazul-partial" "$TEMPLATES_DIR/skills"/*; do
    [ -d "$skill_dir" ] || continue
    name=$(basename "$skill_dir")
    
    # Mapping for JIT forge artifacts
    if [ "$name" = "jacazul-partial" ]; then
        name="jacazul"
    fi

    # 🚨 EXCLUSION: jacazul is NOT a skill for Opencode, it is an agent.
    # In the new architecture, it IS a skill too (for delegation).

    target="$OPENCODE_GLOBAL_DIR/skills/$name"
    # Always ensure the link points to the CURRENT PROJECT_ROOT
    if [ -L "$target" ]; then
        current_target=$(readlink -f "$target")
        expected_target=$(readlink -f "$skill_dir")
        if [ "$current_target" != "$expected_target" ]; then
            echo "⚠️  Skill $name points to wrong location. Re-linking..."
            ln -sf "$skill_dir" "$target"
        fi
    else
        echo "🐊 Linking global skill: $name"
        ln -sf "$skill_dir" "$target"
    fi
done

# Log only in DEBUG mode
if [ -n "$DEBUG" ]; then
    echo "✅ Jacazul: Global Opencode environment verified."
fi
