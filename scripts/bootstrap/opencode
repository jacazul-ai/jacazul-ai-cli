#!/bin/bash
# 🐊 Jacazul - Bootstrap for Opencode (Global UNHINGED Mode)
# Sets up global agents and skills for native Opencode CLI execution.

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
OPENCODE_GLOBAL_DIR="$HOME/.config/opencode"
TEMPLATES_DIR="$PROJECT_ROOT/templates"

# 1. Garante que os diretórios globais existem
for d in "agents" "skills"; do
    target="$OPENCODE_GLOBAL_DIR/$d"
    if [ -L "$target" ]; then
        if [ -n "$DEBUG" ]; then echo "🐊 Removing legacy symlink at $target"; fi
        rm "$target"
    fi
    mkdir -p "$target"
done

# 2. Link Global Agents (Surgical)
AGENT_SRC="$PROJECT_ROOT/agents/jacazul-opencode.md"
AGENT_TARGET="$OPENCODE_GLOBAL_DIR/agents/jacazul.md"

if [ -e "$AGENT_SRC" ]; then
    if [ -n "$DEBUG" ]; then
        echo "🐊 Linking global Opencode agent: jacazul"
    fi
    ln -sf "$AGENT_SRC" "$AGENT_TARGET"
fi

# 3. Link Global Skills (Surgical)
# Link fixed skills from root-level /skills directory
for skill_dir in "$PROJECT_ROOT/skills"/*; do
    [ -d "$skill_dir" ] || continue
    name=$(basename "$skill_dir")
    
    target="$OPENCODE_GLOBAL_DIR/skills/$name"
    # Always ensure the link points to the CURRENT PROJECT_ROOT
    if [ -L "$target" ]; then
        current_target=$(readlink -f "$target")
        expected_target=$(readlink -f "$skill_dir")
        if [ "$current_target" != "$expected_target" ]; then
            if [ -n "$DEBUG" ]; then
                echo "⚠️  Skill $name points to wrong location. Re-linking..."
            fi
            ln -sf "$skill_dir" "$target"
        fi
    else
        if [ -n "$DEBUG" ]; then
            echo "🐊 Linking global skill: $name"
        fi
        ln -sf "$skill_dir" "$target"
    fi
done

# 3.1 Link legacy skills from templates (if any left)
if [ -d "$TEMPLATES_DIR/skills" ]; then
    for skill_dir in "$TEMPLATES_DIR/skills"/*; do
        [ -d "$skill_dir" ] || continue
        name=$(basename "$skill_dir")

        # Skip if already linked from root
        [ -e "$OPENCODE_GLOBAL_DIR/skills/$name" ] && continue

        target="$OPENCODE_GLOBAL_DIR/skills/$name"
        if [ -n "$DEBUG" ]; then
            echo "🐊 Linking legacy skill from templates: $name"
        fi
        ln -sf "$skill_dir" "$target"
    done
fi

# Log only in DEBUG mode
if [ -n "$DEBUG" ]; then
    echo "✅ Jacazul: Global Opencode environment verified."
fi
