#!/bin/bash
# 🐊 Jacazul Taskwarrior Bootstrap
# Sets TASKDATA based on JACAZUL_MODE and PROJECT_ID

if [ -n "$PROJECT_ID" ]; then
    export JACAZUL_HOME="$HOME/.jacazul-ai"
    export TASKDATA="$JACAZUL_HOME/.task/$PROJECT_ID"

    if [ "$JACAZUL_MODE" = "UNHINGED" ]; then
        export TASKRC="$JACAZUL_HOME/.taskrc"
        
        # Ensure the .taskrc is in place
        if [ ! -f "$TASKRC" ]; then
            echo "🐊 Initializing Unhinged Taskwarrior config at $TASKRC..."
            mkdir -p "$JACAZUL_HOME"
            cp "$PROJECT_ROOT/templates/taskwarrior/unhinged/.taskrc" "$TASKRC"
            # Explicitly override data.location to avoid confusion
            sed -i "s|data.location=.*|data.location=$JACAZUL_HOME/.task|" "$TASKRC"
        else
            # Surgical sync of UDAs from project template to global config
            TEMPLATE_RC="$PROJECT_ROOT/templates/taskwarrior/unhinged/.taskrc"
            if [ -f "$TEMPLATE_RC" ]; then
                grep "^uda\." "$TEMPLATE_RC" | while read -r line; do
                    key=$(echo "$line" | cut -d'=' -f1)
                    if ! grep -q "^$key=" "$TASKRC"; then
                        if [ -n "$DEBUG" ]; then echo "🐊 Injecting missing UDA from project: $line"; fi
                        echo "$line" >> "$TASKRC"
                    fi
                done
            fi
            # Always ensure data.location is correct in the existing config
            if ! grep -q "data.location=$JACAZUL_HOME/.task" "$TASKRC"; then
                 sed -i "s|data.location=.*|data.location=$JACAZUL_HOME/.task|" "$TASKRC"
            fi
        fi
    fi

    # Create task data directory if missing
    if [ ! -d "$TASKDATA" ]; then
        echo "🐊 Creating task data directory: $TASKDATA"
        mkdir -p "$TASKDATA"
    fi

    # Taskwarrior 2.x to 3.x Migration (Taskchampion)
    TW_VERSION=$(task --version | head -n 1 | cut -d'.' -f1)
    if [ "$TW_VERSION" -eq 3 ]; then
        # Check if legacy data exists but SQLite doesn't
        if [ -f "$TASKDATA/pending.data" ] && [ ! -f "$TASKDATA/taskchampion.sqlite3" ]; then
            echo "⚠️  Detected Taskwarrior 2.x data in version 3 environment."
            echo "🐊 Migrating database to SQLite (task import-v2)..."
            # Backup first just in case
            BACKUP_DIR="$JACAZUL_HOME/.task-backups/migration-$(date +%Y%m%d-%H%M%S)"
            mkdir -p "$BACKUP_DIR"
            cp "$TASKDATA/"*.data "$BACKUP_DIR/"
            
            # Perform import
            # rc.hooks=0 to avoid triggering hooks during import
            task import-v2 rc.hooks=0
            if [ $? -eq 0 ]; then
                echo "✅ Migration successful."
                # Keep legacy files as backup for now, or move them?
                # User said "check if current TASKDATA was converted", so we do it.
            else
                echo "❌ Migration failed! Please check logs."
            fi
        fi
    fi

    # Emit logs only in DEBUG mode
    if [ -n "$DEBUG" ]; then
        echo "🐊 Task Data: $TASKDATA"
        [ -n "$TASKRC" ] && echo "🐊 Task RC: $TASKRC"
    fi
fi
